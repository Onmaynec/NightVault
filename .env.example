NIGHTVAULT_HOST=127.0.0.1
NIGHTVAULT_PORT=3000
NIGHTVAULT_DATA_DIR=./server/runtime
NIGHTVAULT_PUBLIC_URL=http://127.0.0.1:3000
NIGHTVAULT_CORS_ORIGINS=null
NIGHTVAULT_ACCESS_MINUTES=30
NIGHTVAULT_REFRESH_DAYS=30
NIGHTVAULT_MAX_JSON_MB=1
NIGHTVAULT_MAX_FILE_MB=50
